{
	"extends": ["@rbinflow/eslint-config/next"],
	"rules": {
		"prettier/prettier": [
			"error",
			{
				"printWidth": 80,
				"tabWidth": 2,
				"useTabs": false,
				"singleQuote": true,
				"trailingComma": "all",
				"arrowParens": "always",
				"semi": false,
				"endOfLine": "lf",
				"bracketSpacing": true,
				"bracketSameLine": false
			}
		]
	}
}
