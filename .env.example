# ────────────────────────────────
# Firebase Configuration (Client)
# ────────────────────────────────
# Estas variáveis são expostas no cliente (NEXT_PUBLIC_*)
# Encontre essas informações no Firebase Console > Project Settings > General

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ────────────────────────────────
# Firebase Configuration (Server)
# ────────────────────────────────
# Service Account JSON codificado em base64
# Para gerar: cat service-account.json | base64
# Ou no Node.js: Buffer.from(JSON.stringify(serviceAccount)).toString('base64')

GCP_SERVICE_ACCOUNT=your-base64-encoded-service-account-json
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# ────────────────────────────────
# Application Configuration
# ────────────────────────────────

NEXT_PUBLIC_APP_NAME=lucy
NEXT_PUBLIC_VERCEL_URL=http://localhost:3000

# ────────────────────────────────
# Optional: Skip Environment Validation
# ────────────────────────────────
# Descomente para pular validação de variáveis de ambiente (não recomendado)
# SKIP_ENV_VALIDATION=false
